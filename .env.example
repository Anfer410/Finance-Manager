# Copy this file to .env and fill in the required values.
# Then run: docker compose up -d

# ── Image ──────────────────────────────────────────────────────────────────────
# Tag to pull from ghcr.io/anfer410/finance-manager
IMAGE_TAG=latest

# ── Database ───────────────────────────────────────────────────────────────────
#
# OPTION A — Bundled Postgres (default, recommended for new installs)
#   Keep COMPOSE_PROFILES=db. A Postgres container will start alongside the app.
#   DB_HOST must be "db" (the internal service name).
#
COMPOSE_PROFILES=db
DB_HOST=db
DB_PORT=5432
DB_DATA_PATH=./data/db      # host path for Postgres data (bind mount — easy to back up)
DB_NAME=finance-manager
DB_USER=postgres
DB_PASSWORD=change-me        # required — set a strong password

# OPTION B — External / existing Postgres
#   Remove (or comment out) COMPOSE_PROFILES=db above.
#   Set DB_HOST to your database server and adjust the other values as needed.
#
# COMPOSE_PROFILES=
# DB_HOST=your-postgres-host
# DB_PORT=5432
# DB_NAME=finance-manager
# DB_USER=postgres
# DB_PASSWORD=your-password

# ── App ────────────────────────────────────────────────────────────────────────
# NiceGUI session secret — use a long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
STORAGE_SECRET=change-me     # required — set a unique secret

# Port the app is exposed on (default: 8080)
# APP_PORT=8080

# ── Timezone ───────────────────────────────────────────────────────────────────
TZ=UTC
